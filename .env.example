# WorshipFlow 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===========================================
# Google Cloud 配置
# ===========================================

# Google Cloud 项目ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Cloud Storage 存储桶名称 (可选，默认使用 PROJECT_ID-worshipflow-data)
GCS_BUCKET_NAME=your-bucket-name

# ===========================================
# Google Gemini API 配置
# ===========================================

# Gemini API Key (推荐用于本地开发)
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# 或者使用 Service Account (推荐用于生产环境)
# 服务账户密钥文件路径
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# ===========================================
# Streamlit 配置 (可选)
# ===========================================

# 应用端口 (Cloud Run 会自动设置)
PORT=8080

# ===========================================
# 部署配置
# ===========================================

# Cloud Run 服务名称
SERVICE_NAME=worshipflow

# 部署区域
REGION=us