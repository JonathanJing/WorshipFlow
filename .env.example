# WorshipFlow Environment Configuration Example
# WorshipFlow 环境配置示例文件

# =============================================================================
# Google Cloud Configuration / Google Cloud 配置
# =============================================================================

# Google Cloud Project ID (required for cloud deployment)
# Google Cloud 项目ID（云端部署必需）
GOOGLE_CLOUD_PROJECT=your-project-id

# Path to Google Cloud service account JSON file
# Google Cloud 服务账号JSON文件路径
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Google Cloud Storage bucket name for data storage
# 用于数据存储的Google Cloud Storage存储桶名称
GCS_BUCKET_NAME=your-bucket-name

# =============================================================================
# AI Model Configuration / AI模型配置
# =============================================================================

# Gemini API Key (alternative to service account for AI features)
# Gemini API密钥（AI功能的服务账号替代方案）
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# AI model to use for generation tasks
# 用于生成任务的AI模型
# Available options: gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# Storage Configuration / 存储配置
# =============================================================================

# Force local storage mode (useful for development)
# 强制本地存储模式（适用于开发环境）
# Set to 'true' to disable cloud storage and use local 'data/' folder only
# 设置为'true'可禁用云存储，仅使用本地'data/'文件夹
FORCE_LOCAL_STORAGE=false

# =============================================================================
# Logging Configuration / 日志配置
# =============================================================================

# Enable/disable user action logging
# 启用/禁用用户行为日志记录
ENABLE_USER_LOGGING=true

# Disable Google Cloud Logging (use local files only)
# 禁用Google Cloud Logging（仅使用本地文件）
# Set to 'true' to force local file logging even in cloud environment
# 设置为'true'可在云环境中强制使用本地文件日志
DISABLE_CLOUD_LOGGING=false

# =============================================================================
# Deployment Configuration / 部署配置
# =============================================================================

# Application port (Cloud Run will set this automatically)
# 应用端口（Cloud Run会自动设置）
PORT=8080

# Cloud Run service name
# Cloud Run服务名称
SERVICE_NAME=worship-flow

# Deployment region
# 部署区域
REGION=us-central1

# =============================================================================
# Feature Flags / 功能开关
# =============================================================================

# Enable AI transition generation feature
# 启用AI串词生成功能
ENABLE_AI_TRANSITIONS=true

# Enable song management feature
# 启用诗歌管理功能
ENABLE_SONG_MANAGEMENT=true

# Enable flow design feature
# 启用流程设计功能
ENABLE_FLOW_DESIGN=true

# Enable rehearsal mode
# 启用排练模式
ENABLE_REHEARSAL_MODE=true

# =============================================================================
# Usage Examples / 使用示例
# =============================================================================

# Example 1: Local Development Setup / 本地开发设置
# Copy these values to .env.local for local development:
# ------------------------------------------------------------------------
# FORCE_LOCAL_STORAGE=true
# ENABLE_USER_LOGGING=true
# DISABLE_CLOUD_LOGGING=true
# GEMINI_API_KEY=your-api-key
# GEMINI_MODEL=gemini-2.5-flash

# Example 2: Cloud Production Setup / 云端生产设置
# Set these as environment variables in Cloud Run:
# ------------------------------------------------------------------------
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCS_BUCKET_NAME=worshipflow-data
# FORCE_LOCAL_STORAGE=false
# ENABLE_USER_LOGGING=true
# DISABLE_CLOUD_LOGGING=false
# GEMINI_MODEL=gemini-2.5-flash

# Example 3: Testing Environment / 测试环境
# For automated testing with minimal features:
# ------------------------------------------------------------------------
# FORCE_LOCAL_STORAGE=true
# ENABLE_USER_LOGGING=false
# GEMINI_MODEL=gemini-2.5-flash
# ENABLE_AI_TRANSITIONS=false

# =============================================================================
# Important Notes / 重要说明
# =============================================================================

# 1. Security / 安全性
#    - Never commit actual credentials to version control
#    - 永远不要将实际凭据提交到版本控制
#    - Use .env.local for local development overrides
#    - 使用.env.local进行本地开发覆盖

# 2. File Priority / 文件优先级
#    - .env.local (highest priority, local development)
#    - .env (standard configuration)
#    - Environment variables (cloud deployment)

# 3. Required Dependencies / 必需依赖
#    - For cloud features: pip install google-cloud-storage google-cloud-logging
#    - For local only: pip install python-dotenv streamlit

# 4. Documentation / 文档
#    - Refer to LOCAL_SETUP.md for local development setup
#    - 本地开发设置请参考LOCAL_SETUP.md
#    - Refer to LOGGING_GUIDE.md for detailed logging configuration
#    - 详细的日志配置请参考LOGGING_GUIDE.md
#    - Refer to DEPLOYMENT.md for cloud deployment instructions
#    - 云端部署说明请参考DEPLOYMENT.md

# 5. Troubleshooting / 故障排除
#    - Check logs in logs/ directory or Google Cloud Console
#    - Verify all required environment variables are set
#    - Ensure proper GCP authentication and permissions
#    - Test with FORCE_LOCAL_STORAGE=true first for debugging